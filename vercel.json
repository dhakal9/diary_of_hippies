{
  "version": 2,

  "buildCommand": "bash build.sh",

  "builds": [
    {
      "src": "core/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    }
  ],

  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}